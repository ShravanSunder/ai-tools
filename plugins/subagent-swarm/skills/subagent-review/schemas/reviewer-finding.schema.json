{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-tools.local/subagent-swarm/reviewer-finding.schema.json",
  "title": "Subagent Swarm Reviewer Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "severity",
    "title",
    "evidence",
    "scenario",
    "smallest_fix",
    "proof",
    "confidence",
    "sources"
  ],
  "properties": {
    "severity": {
      "type": "string",
      "enum": ["blocker", "important", "follow-up", "nit"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "smallest_fix": {
      "type": "string",
      "minLength": 1
    },
    "proof": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
