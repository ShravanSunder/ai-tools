{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-tools.local/shravan-dev-workflow/swarm-report.schema.json",
  "title": "Shravan Dev Workflow Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "verdict",
    "scope",
    "review_packet",
    "findings",
    "open_questions",
    "coverage"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["implementation", "diff", "pr", "commit", "plan", "files", "adversarial"]
    },
    "verdict": {
      "type": "string",
      "enum": ["ready", "ready_with_fixes", "not_ready"]
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "review_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "constraints", "git_range", "changed_files"],
      "properties": {
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "string"
        },
        "git_range": {
          "type": "object",
          "additionalProperties": false,
          "required": ["base_sha", "head_sha", "diff_stat_command", "diff_command"],
          "properties": {
            "base_sha": {
              "type": "string"
            },
            "head_sha": {
              "type": "string"
            },
            "diff_stat_command": {
              "type": "string"
            },
            "diff_command": {
              "type": "string"
            }
          }
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "./reviewer-finding.schema.json"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lanes_run",
        "lanes_skipped",
        "external_model_lanes",
        "skipped_inputs",
        "verification_notes",
        "candidate_count",
        "accepted_count",
        "rejected_count"
      ],
      "properties": {
        "lanes_run": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lanes_skipped": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "external_model_lanes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skipped_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "accepted_count": {
          "type": "integer",
          "minimum": 0
        },
        "rejected_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
