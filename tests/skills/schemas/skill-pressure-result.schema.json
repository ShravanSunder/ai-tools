{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario_id",
    "skill_under_test",
    "skill_invoked",
    "mode",
    "read_only",
    "artifact_expected",
    "artifact_created",
    "decision",
    "coverage_evidence",
    "shortcut_resisted",
    "rationalizations_rejected",
    "open_questions",
    "next_action"
  ],
  "properties": {
    "scenario_id": {
      "type": "string"
    },
    "skill_under_test": {
      "type": "string"
    },
    "skill_invoked": {
      "type": "boolean"
    },
    "mode": {
      "enum": [
        "fast",
        "integration",
        "baseline"
      ]
    },
    "read_only": {
      "type": "boolean"
    },
    "artifact_expected": {
      "type": "boolean"
    },
    "artifact_created": {
      "type": "boolean"
    },
    "decision": {
      "type": "string"
    },
    "coverage_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shortcut_resisted": {
      "type": "boolean"
    },
    "rationalizations_rejected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string"
    }
  }
}
