{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "number",
          "const": 3
        },
        "scenario_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "owner_plugin": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "owner_skill": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "skill_type": {
          "type": "string",
          "enum": [
            "discipline",
            "technique",
            "pattern",
            "reference"
          ]
        },
        "effect_surfaces": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "response",
              "artifacts",
              "tools"
            ]
          }
        },
        "prompt": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "semantic_assertions": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "assertion_id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200,
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "criterion": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "evidence_surface": {
                "anyOf": [
                  {
                    "type": "string",
                    "const": "response"
                  },
                  {
                    "type": "string",
                    "const": "tools"
                  },
                  {
                    "type": "string",
                    "pattern": "^artifact:[a-z0-9][a-z0-9-]*$"
                  }
                ]
              }
            },
            "required": [
              "assertion_id",
              "criterion",
              "evidence_surface"
            ],
            "additionalProperties": false
          }
        },
        "behavior_requirement_ids": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "comparison_intent": {
          "type": "string",
          "enum": [
            "improvement",
            "non_regression"
          ]
        },
        "repetitions": {
          "type": "integer",
          "minimum": 3,
          "maximum": 9007199254740991
        },
        "risk": {
          "type": "string",
          "enum": [
            "standard",
            "high"
          ]
        },
        "fixture_requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "allowed_tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "allowed_write_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "pattern": "^(?!\\/)(?!.*\\\\)(?!.*(?:^|\\/)\\.{1,2}(?:\\/|$))(?!.*\\/\\/)(?!.*\\/$).+$"
          }
        },
        "required_tool_observations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "forbidden_tool_observations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "deterministic_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "check_id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200,
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "fact": {
                "anyOf": [
                  {
                    "type": "string",
                    "const": "tool_observations"
                  },
                  {
                    "type": "string",
                    "pattern": "^path:(?!\\/)(?!.*\\\\)(?!.*(?:^|\\/)\\.{1,2}(?:\\/|$))(?!.*\\/\\/)(?!.*\\/$).+$"
                  },
                  {
                    "type": "string",
                    "pattern": "^artifact:[a-z0-9][a-z0-9-]*$"
                  }
                ]
              },
              "operator": {
                "type": "string",
                "enum": [
                  "equals",
                  "contains",
                  "excludes",
                  "matches",
                  "not_matches",
                  "exists",
                  "absent"
                ]
              },
              "expected": {}
            },
            "required": [
              "check_id",
              "fact",
              "operator"
            ],
            "additionalProperties": false
          }
        },
        "expected_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifact_id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200,
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512,
                "pattern": "^(?!\\/)(?!.*\\\\)(?!.*(?:^|\\/)\\.{1,2}(?:\\/|$))(?!.*\\/\\/)(?!.*\\/$).+$"
              },
              "file_type": {
                "type": "string",
                "enum": [
                  "file",
                  "directory"
                ]
              },
              "content_contract": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              }
            },
            "required": [
              "artifact_id",
              "path",
              "file_type",
              "content_contract"
            ],
            "additionalProperties": false
          }
        },
        "baseline": {
          "type": "string",
          "const": "no_skill"
        }
      },
      "required": [
        "schema_version",
        "scenario_id",
        "owner_plugin",
        "owner_skill",
        "skill_type",
        "effect_surfaces",
        "prompt",
        "semantic_assertions",
        "behavior_requirement_ids",
        "comparison_intent",
        "repetitions",
        "risk",
        "fixture_requirements",
        "allowed_tools",
        "allowed_write_paths",
        "required_tool_observations",
        "forbidden_tool_observations",
        "deterministic_checks",
        "expected_artifacts",
        "baseline"
      ],
      "additionalProperties": false
    },
