{
	"name": "agent_vm",
	"version": "0.1.0",
	"private": true,
	"description": "Gondolin-based VM control plane with sidecar parity",
	"bin": {
		"agent-vm-ctl": "./dist/bin/agent-vm-ctl.js",
		"agent-vm-daemon": "./dist/bin/agent-vm-daemon.js",
		"run-agent-vm": "./dist/bin/run-agent-vm.js"
	},
	"type": "module",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"typecheck": "tsc -p tsconfig.typecheck.json",
		"test": "vitest run --project unit --project integration",
		"test:e2e": "pnpm build && vitest run --project e2e",
		"check": "pnpm lint && pnpm fmt:check && pnpm typecheck && pnpm test && pnpm test:e2e"
	},
	"dependencies": {
		"cmd-ts": "^0.14.0",
		"execa": "^9.5.2",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.0.0",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	},
	"optionalDependencies": {
		"@earendil-works/gondolin": "latest"
	}
}
