{
	"$id": "tcp-services",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"services": {
			"type": "object",
			"propertyNames": {
				"type": "string",
				"minLength": 1
			},
			"additionalProperties": {
				"type": "object",
				"properties": {
					"guestHostname": {
						"type": "string",
						"minLength": 1
					},
					"guestPort": {
						"type": "integer",
						"minimum": 1,
						"maximum": 65535
					},
					"upstreamTarget": {
						"type": "string",
						"minLength": 1
					},
					"enabled": {
						"default": true,
						"type": "boolean"
					}
				},
				"additionalProperties": false
			}
		},
		"strictMode": {
			"type": "boolean"
		},
		"allowedTargetHosts": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		}
	},
	"additionalProperties": false
}
